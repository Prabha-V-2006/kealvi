# Copy this file to .env.local and fill in your Supabase project values.
# From the Supabase dashboard: Settings → API.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Day 6 — Google Gemini, free at https://aistudio.google.com (no card).
# Server-only, like the Supabase key. Restart `npm run dev` after adding it.
GEMINI_API_KEY=AIza...your-key
